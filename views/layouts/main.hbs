<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} | PhonePal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo">
        <div class="logo-mark">P</div>
        Phone<span>Pal</span>
      </a>
      <ul class="nav-links">
        <li><a href="/devices">Devices</a></li>
        <li><a href="/plans">Plans</a></li>
        <li><a href="/deals">Deals</a></li>
        <li><a href="/support">Support</a></li>
      </ul>
      <div class="nav-actions">
        <a href="/login" class="btn btn-outline">Sign in</a>
        <a href="/cart" class="nav-cart" aria-label="Basket">
          🛒
          {{#if cartCount}}
          <span class="nav-cart-count">{{cartCount}}</span>
          {{/if}}
        </a>
      </div>
      <button class="nav-hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  {{{body}}}

  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="nav-logo" style="color:#fff">
            <div class="logo-mark">P</div>
            Phone<span style="color:#009CDE">Pal</span>
          </div>
          <p class="footer-brand-desc">The smarter way to stay connected. Great devices, flexible plans, and the security of PayPal payments.</p>
        </div>
        <div>
          <p class="footer-col-title">Devices</p>
          <ul class="footer-links">
            <li><a href="#">Latest Phones</a></li>
            <li><a href="#">Refurbished</a></li>
            <li><a href="#">Accessories</a></li>
            <li><a href="#">Trade In</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-col-title">Plans</p>
          <ul class="footer-links">
            <li><a href="#">Pay Monthly</a></li>
            <li><a href="#">Pay As You Go</a></li>
            <li><a href="#">SIM Only</a></li>
            <li><a href="#">Business</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-col-title">Company</p>
          <ul class="footer-links">
            <li><a href="#">About Us</a></li>
            <li><a href="#">Careers</a></li>
            <li><a href="#">Press</a></li>
            <li><a href="#">Contact</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© 2026 PhonePal Ltd. All rights reserved.</span>
        <div class="footer-bottom-links">
          <a href="#">Privacy</a>
          <a href="#">Terms</a>
          <a href="#">Cookies</a>
        </div>
      </div>
    </div>
  </footer>

</body>
</html>
